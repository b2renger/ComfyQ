{
  "schemaVersion": 1,
  "id": "utility_video_segment_sam3",
  "name": "SAM3 — text-prompted video segmentation",
  "description": "Isolate an object in a video just by naming it. Upload a video and type what to track (e.g. \"person\", \"dog\", \"red car\") — SAM3 finds that object in every frame and outputs a black-and-white **mask video** (white = the object, black = everything else), ready to use as a matte / luma key in compositing.\n\nTip: use a short, concrete noun or noun phrase. Lower the detection threshold to catch more (looser), raise it to be stricter. Output frames line up 1:1 with the source.",
  "category": "preprocessor",
  "tags": [
    "sam3",
    "segmentation",
    "mask",
    "matte",
    "video",
    "utility"
  ],
  "thumbnail": null,
  "author": "Template - ComfyUI",
  "version": "1.0.0",
  "workflowFile": "utility_video_segment_sam3.api.json",
  "apiFormat": true,
  "requirements": {
    "minVRAM": 8,
    "models": [
      {
        "type": "checkpoint",
        "file": "sam3.1_multiplex_fp16.safetensors"
      }
    ]
  },
  "estimatedDurationSec": 60,
  "exposedParameters": [
    {
      "key": "source_video_115",
      "nodeId": "115",
      "field": "file",
      "type": "video",
      "label": "Source video",
      "default": "",
      "required": true,
      "order": 0
    },
    {
      "key": "segment_text_114_100",
      "nodeId": "114:100",
      "field": "text",
      "type": "text",
      "label": "What to segment",
      "default": "person",
      "required": true,
      "order": 1
    },
    {
      "key": "threshold_114_101",
      "nodeId": "114:101",
      "field": "threshold",
      "type": "number",
      "label": "Detection threshold",
      "default": 0.5,
      "min": 0.1,
      "max": 0.9,
      "step": 0.05,
      "required": false,
      "order": 2
    }
  ],
