{
    "name": "comfyq",
    "version": "2.0.0",
    "description": "ComfyQ — multi-user middleware for ComfyUI workflow scheduling",
    "main": "server/index.js",
    "engines": {
        "node": ">=22.0.0 <25.0.0"
    },
    "scripts": {
        "start": "node server/index.js",
        "client": "npm run dev --prefix client",
        "server": "nodemon server/index.js --watch server",
        "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
        "desktop": "npm --prefix desktop start",
        "desktop:install": "npm install --prefix desktop && node desktop/node_modules/electron/install.js",
        "postinstall": "npm install --prefix client && npm install --prefix server"
    },
    "dependencies": {
        "concurrently": "^8.2.2"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
